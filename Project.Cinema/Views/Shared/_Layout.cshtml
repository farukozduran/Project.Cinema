<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - CineReserve</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/cinema.css" asp-append-version="true" />
</head>
<body>
    <header class="cinema-header">
        <nav class="navbar navbar-expand-lg cinema-navbar">
            <div class="container">
                <a class="navbar-brand cinema-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">🎬</span>
                    CineReserve
                </a>

                <button class="navbar-toggler cinema-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    ☰
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="UserPanel">User Panel</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="AdminPanel">Admin Panel</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Movies" asp-action="Index">Filmler</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Sessions" asp-action="Index">Seanslar</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Announcements" asp-action="Index">Duyurular</a>
                        </li>

                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-cinema-primary btn-sm" asp-controller="Home" asp-action="UserPanel">
                                Bilet Al
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="cinema-main">
        @RenderBody()
    </main>

    <footer class="cinema-footer">
        <div class="container">
            <div class="row g-4 align-items-start">
                <div class="col-md-5">
                    <h5 class="footer-logo">🎬 CineReserve</h5>
                    <p>
                        AJAX ve jQuery ile geliştirilen film seans rezervasyon sistemi.
                        Admin tarafında CRUD işlemleri, user tarafında bilet listesi mantığı bulunur.
                    </p>
                </div>

                <div class="col-md-3">
                    <h6>Yönetim</h6>
                    <a asp-controller="Movies" asp-action="Index">Film Yönetimi</a>
                    <a asp-controller="Sessions" asp-action="Index">Seans Yönetimi</a>
                    <a asp-controller="Announcements" asp-action="Index">Duyuru Yönetimi</a>
                </div>

                <div class="col-md-2">
                    <h6>Paneller</h6>
                    <a asp-controller="Home" asp-action="UserPanel">User Panel</a>
                    <a asp-controller="Home" asp-action="AdminPanel">Admin Panel</a>
                </div>

                <div class="col-md-2">
                    <h6>Proje</h6>
                    <span>ASP.NET Core MVC</span>
                    <span>AJAX / jQuery</span>
                    <span>SQL Server</span>
                </div>
            </div>

            <div class="footer-bottom">
                <span>&copy; 2026 CineReserve</span>
                <span>Dark cinema theme</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/custom.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>