@{
    ViewData["Title"] = "User Panel";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div class="page-head mb-0">
            <h1>User Panel</h1>
            <p>Seansları inceleyip bilet listene ekleyebilirsin.</p>
        </div>

        <div class="cinema-card py-3 px-4 d-flex align-items-center gap-3">
            <span style="font-size: 1.7rem;">🎟️</span>
            <div>
                <small class="text-muted d-block">Bilet Listesi</small>
                <span id="cartCount" class="cart-badge">0</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-9">
            <div class="cinema-card">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                    <div>
                        <h3 class="mb-1">Seanslar</h3>
                        <p class="text-muted mb-0">
                            Uygun seansı seçip bilet listene ekleyebilirsin.
                        </p>
                    </div>

                    <button id="clearCartBtn" class="btn btn-cinema-outline">
                        Sepeti Boşalt
                    </button>
                </div>

                <div id="userSessionList" class="row g-3 mt-2">
                    <!-- Seans kartları AJAX ile buraya gelecek -->
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="cinema-card">
                <h4>Sepet Bilgisi</h4>
                <p class="text-muted">
                    Şu anda bilet listende:
                </p>

                <div class="d-flex align-items-center gap-3">
                    <span style="font-size: 2rem;">🎫</span>
                    <div>
                        <strong id="cartInfoText">0 bilet</strong>
                        <small class="text-muted d-block">seçili durumda</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/userPanel.js" asp-append-version="true"></script>
}