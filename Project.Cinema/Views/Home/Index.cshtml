@{
    ViewData["Title"] = "Ana Sayfa";
}

<section class="cinema-hero">
    <div class="container">
        <div class="hero-card">
            <div class="hero-content">
                <div class="hero-kicker">Cinema Booking System</div>

                <h1 class="hero-title">
                    Film seanslarını keşfet, bilet listeni oluştur.
                </h1>

                <p class="hero-text">
                    CineReserve; film, seans ve duyuru yönetimi için hazırlanmış
                    ASP.NET Core MVC, AJAX ve jQuery tabanlı modern bir sinema rezervasyon projesidir.
                </p>

                <div class="d-flex flex-wrap gap-3 mt-4">
                    <a asp-controller="Home" asp-action="UserPanel" class="btn btn-cinema-primary px-4 py-2">
                        User Girişi
                    </a>

                    <a asp-controller="Home" asp-action="AdminPanel" class="btn btn-cinema-outline px-4 py-2">
                        Admin Girişi
                    </a>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <span class="stat-pill">AJAX CRUD</span>
                    <span class="stat-pill">jQuery</span>
                    <span class="stat-pill">SQL Server</span>
                    <span class="stat-pill">Dark UI</span>
                </div>
            </div>
        </div>
    </div>
</section>