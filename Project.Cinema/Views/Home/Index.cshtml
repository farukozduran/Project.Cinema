@{
    ViewData["Title"] = "Ana Sayfa";
}

<section class="welcome-section">
    <div class="container">
        <div class="welcome-card text-center">
            <span class="welcome-icon">🎬</span>

            <p class="hero-kicker">CineReserve</p>

            <h1 class="hero-title">
                Sinema Seans Rezervasyon Sistemine Hoş Geldiniz
            </h1>

            <p class="hero-text mx-auto">
                Güncel film seanslarını görüntüleyebilir, istediğiniz seansı bilet listenize ekleyebilirsiniz.
                Admin panelinden ise film, seans ve duyuru kayıtları yönetilebilir.
            </p>

            <div class="d-flex justify-content-center flex-wrap gap-3 mt-4">
                <a asp-controller="Home" asp-action="UserPanel" class="btn btn-cinema-primary px-4 py-2">
                    Seansları Görüntüle
                </a>
            </div>

            <div class="d-flex justify-content-center flex-wrap gap-2 mt-4">
                <span class="stat-pill">Film Seansları</span>
                <span class="stat-pill">Bilet Sayacı</span>
                <span class="stat-pill">AJAX CRUD</span>
                <span class="stat-pill">Admin Yönetimi</span>
            </div>
        </div>
    </div>
</section>