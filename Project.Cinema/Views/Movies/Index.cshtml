@{
    ViewData["Title"] = "Film Yönetimi";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div class="page-head mb-0">
            <h1>Film Yönetimi</h1>
            <p>Filmleri AJAX ile listele, ekle, düzenle ve sil.</p>
        </div>

        <button type="button"
                class="btn btn-cinema-primary"
                data-bs-toggle="modal"
                data-bs-target="#movieModal"
                onclick="openAddMovieModal()">
            + Yeni Film Ekle
        </button>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Film</th>
                        <th>Tür</th>
                        <th>Yönetmen</th>
                        <th>Süre</th>
                        <th>Açıklama</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="movieTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="movieModal" tabindex="-1" aria-labelledby="movieModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="movieModalLabel" class="modal-title">Yeni Film Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="movieId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Film Adı</label>
                        <input type="text" id="movieTitle" class="form-control" placeholder="Örn: Interstellar" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Tür</label>
                        <input type="text" id="genre" class="form-control" placeholder="Örn: Bilim Kurgu" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Yönetmen</label>
                        <input type="text" id="director" class="form-control" placeholder="Örn: Christopher Nolan" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Süre</label>
                        <input type="number" id="duration" class="form-control" placeholder="Dakika" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Görsel URL</label>
                        <input type="text" id="imageUrl" class="form-control" placeholder="Film afiş linki" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Açıklama</label>
                        <textarea id="description" class="form-control" placeholder="Film açıklaması"></textarea>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-cinema-outline" data-bs-dismiss="modal">Kapat</button>
                <button type="button" id="btnAddMovie" class="btn btn-cinema-primary" onclick="addMovie()">Kaydet</button>
                <button type="button" id="btnUpdateMovie" class="btn btn-warning" onclick="updateMovie()" style="display:none;">Güncelle</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/movies.js" asp-append-version="true"></script>
}